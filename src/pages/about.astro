---
import Layout from '../layouts/Layout.astro';
import AboutPage from '../components/AboutPage';
---

<Layout>
	<main class="about-page">
		<AboutPage client:load />
	</main>
</Layout>

<style>
	.about-page {
		padding: 0 2rem 2rem;
		max-width: 1200px;
		margin: 0 auto;
	}

	@media (max-width: 768px) {
		.about-page {
			padding: 1rem;
		}
	}
</style>
