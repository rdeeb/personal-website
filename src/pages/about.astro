---
import Layout from '../layouts/Layout.astro';
import AboutPage from '../components/AboutPage';
---

<Layout title="About | Ramy Deeb" description="Learn about Ramy Deeb — Senior Full Stack Developer with 20+ years of experience, his background, key achievements, and personal interests.">
	<main class="about-page">
		<AboutPage client:load />
	</main>
</Layout>

<style>
	.about-page {
		padding: 0 2rem 2rem;
		max-width: 1200px;
		margin: 0 auto;
	}

	@media (max-width: 768px) {
		.about-page {
			padding: 1rem;
		}
	}
</style>
