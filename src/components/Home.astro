---
import Panel from './Panel/Panel';
import Button from './Button/Button';
import { User } from 'pixelarticons/react/User';
import { Grid3x3 } from 'pixelarticons/react/Grid3x3';
import { Terminal } from 'pixelarticons/react/Terminal';
import { Heart } from 'pixelarticons/react/Heart';
import { Camera } from 'pixelarticons/react/Camera';
import heroImg from '../assets/hero_img.jpg';
import projectsData from '../content/projects.json';

const featuredProjects = projectsData.slice(0, 2);
---

<div class="home-container">
  <!-- Hero Section -->
  <section class="hero-section">
    <Panel title="Hello, I'm Ramy!" icon={User} client:load>
      <div class="hero-content">
        <img alt="Ramy's profile picture" src={heroImg.src} class="profile-picture" />
        <div class="hero-text">
          <p>
            Senior Full Stack Developer with 20+ years of experience. I specialise in React,
            TypeScript, and API-driven frontends — building performant interfaces that work,
            ship on time, and hold up over time.
          </p>
          <p>
            This is my corner of the web — projects I've built, work I'm proud of,
            and a bit about what I'm into outside of code.
          </p>
        </div>
      </div>
    </Panel>
  </section>

  <!-- Projects Section -->
  <section class="projects-section">
    <Panel title="Featured Projects" icon={Grid3x3} client:load>
      <div class="projects-container">
        <p>A few recent picks — the full list is on the Projects page.</p>
        <div class="project-list">
          {featuredProjects.map((project) => (
            <div class="project-item">
              <h4>{project.name}</h4>
              <p>{project.description}</p>
              <div class="project-home-links">
                {project.live_url && (
                  <Button 
                    href={project.live_url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    variant="green"
                    size="small"
                    client:load
                  >
                    Live Demo
                  </Button>
                )}
                {project.github_url && (
                  <Button 
                    href={project.github_url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    variant="yellow"
                    size="small"
                    client:load
                  >
                    GitHub
                  </Button>
                )}
              </div>
            </div>
          ))}
        </div>
        <a href="/projects" class="view-all-link">View all projects →</a>
      </div>
    </Panel>
  </section>
</div>

<style>
  .home-container {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .hero-content p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .view-all-link {
    font-family: var(--font-vt323);
    font-size: 1.1rem;
    color: var(--azure-175);
    text-decoration: none;
    margin-top: auto;
  }

  .view-all-link:hover {
    text-decoration: underline;
  }

  .project-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin: 15px 0;
  }

  .project-item {
    padding: 12px;
    border: 1px dashed var(--interface-border-dark);
    border-radius: var(--ui-border-radius);
    display: flex;
    flex-direction: column;
  }

  .project-item h4 {
    margin: 0 0 5px 0;
    color: var(--blue-200);
  }

  .project-item p {
    font-size: 0.9rem;
    margin: 0 0 10px 0;
  }

  .project-home-links {
    display: flex;
    gap: 10px;
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .project-list {
      grid-template-columns: 1fr;
    }
  }
</style>
