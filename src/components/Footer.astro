---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content">
    <p>&copy; {currentYear} Ramy Deeb. All rights reserved.</p>
    <div class="footer-links">
      <a href="https://github.com/rdeeb" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://linkedin.com/in/rdeeb" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--spacing-9);
    padding: var(--spacing-8) var(--spacing-6);
    border-top: 1px solid var(--interface-border-light);
    color: var(--interface-text);
    font-family: var(--font-vt323);
    position: sticky;
    bottom: 0;
    background-color: var(--interface-bg);
    z-index: 10;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 15px;
  }

  .footer-content p {
    margin: 0;
    font-size: 1.1rem;
  }

  .footer-links {
    display: flex;
    gap: var(--spacing-6);
  }

  .footer-links a {
    color: var(--interface-text);
    text-decoration: none;
    font-size: 1.1rem;
  }

  .footer-links a:hover {
    color: var(--azure-175);
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
